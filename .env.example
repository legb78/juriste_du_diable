# Obtenez une clé sur https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Identifiants API Légifrance (PISTE) — inscription sur https://api.gouv.fr/les-api/api-legifrance
LEGIFRANCE_CLIENT_ID=your_client_id_here
LEGIFRANCE_CLIENT_SECRET=your_client_secret_here

# AWS S3 — OPTIONNEL : sauvegarde du corpus et alimentation du déploiement.
# Sans ces clés, le pipeline local fonctionne normalement (envoi S3 ignoré).
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=eu-west-3
AWS_S3_BUCKET=your_bucket_name_here
